rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - role: string (required, ['admin', 'client'])
    //   - createdAt: timestamp (optional)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - clientId: string (required)
    //   - title: string (required)
    //   - status: string (required, ['planning', 'design', 'development', 'testing', 'completed'])
    //   - progress: number (required, 0-100)
    //   - description: string (optional)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: projects/{projectId}/messages
    // Fields:
    //   - projectId: string (required)
    //   - senderId: string (required)
    //   - senderName: string (optional)
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: projects/{projectId}/assets
    // Fields:
    //   - projectId: string (required)
    //   - name: string (required)
    //   - url: string (required, url format)
    //   - type: string (required, ['image', 'document', 'link', 'archive'])
    //   - createdAt: timestamp (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "elkhamrireda@gmail.com");
    }

    function isProjectClient(projectId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'client'] &&
             data.email is string && data.email.size() < 255;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['clientId', 'title', 'status', 'progress']) &&
             data.progress >= 0 && data.progress <= 100 &&
             data.status in ['planning', 'design', 'development', 'testing', 'completed'] &&
             data.title is string && data.title.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role == 'client' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (request.resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isProjectClient(projectId);
        allow create: if (isAdmin() || isProjectClient(projectId)) && request.resource.data.senderId == request.auth.uid;
      }

      match /assets/{assetId} {
        allow read: if isAdmin() || isProjectClient(projectId);
        allow write: if isAdmin();
      }
    }
  }
}
